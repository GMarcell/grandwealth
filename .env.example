# ──────────────────────────────────────────────
# GrandWealth — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ──────────────────────────────────────────────

# ─── Database ─────────────────────────────────
# PostgreSQL connection string. Use your local or hosted Postgres instance.
# Examples:
#   Local:   postgresql://user:password@localhost:5432/grandwealth?schema=public
#   Neon:    postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/grandwealth?sslmode=require
#   Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres?sslmode=require
DATABASE_URL="postgresql://user:password@localhost:5432/grandwealth?schema=public"

# ─── Authentication (NextAuth.js) ────────────
# Generate a strong random secret:
#   openssl rand -hex 32
AUTH_SECRET="your-secret-key-here"

# Full URL of your app (used for auth callbacks).
#   Local:   http://localhost:3000
#   Prod:    https://yourdomain.com
NEXTAUTH_URL="http://localhost:3000"

# ─── Cron / Scheduled Tasks (optional) ───────
# Secret used to secure the cron price-update endpoint.
# Any service calling /api/cron/update-prices must include this as:
#   Authorization: Bearer <CRON_SECRET>
# or as a query parameter: ?secret=<CRON_SECRET>
# If not set, the cron endpoint is publicly accessible (not recommended).
CRON_SECRET="your-cron-secret-here"

# ─── Groq AI (Monthly Analysis) ────────────────────
# API key for Groq AI, used to generate monthly spending & savings analysis.
# Get your free API key at: https://console.groq.com/
GROQ_API_KEY="gsk_your_groq_api_key_here"
