# ============================================
# GrandWealth — Environment Configuration
# ============================================
# Copy this file to `.env` and fill in your values.
#   cp .env.example .env
# ============================================

# ─── Database ────────────────────────────────
# PostgreSQL connection string.
# Supports local, cloud (Neon, Railway, Supabase), or any Postgres-compatible service.
# Examples:
#   Local:   postgresql://postgres:password@localhost:5432/grandwealth?schema=public
#   Neon:    postgresql://user:password@ep-example-123456.us-east-2.aws.neon.tech/grandwealth?sslmode=require
#   Supabase: postgresql://postgres:password@db.xxx.supabase.co:5432/postgres
DATABASE_URL="postgresql://postgres:password@localhost:5432/grandwealth?schema=public"

# ─── NextAuth.js ──────────────────────────────
# Generate a strong random string for session encryption.
#   openssl rand -base64 32
AUTH_SECRET="your-secret-here-change-in-production"

# The canonical URL of your application (used for auth redirects).
# Development:
NEXTAUTH_URL="http://localhost:3000"
# Production (uncomment and set):
# NEXTAUTH_URL=https://yourdomain.com

# ─── Cron Jobs ────────────────────────────────
# Secret key used to secure cron job endpoints.
# Set this to a strong random string.
# Vercel Cron Jobs automatically send this as Bearer token.
# For external cron services (cron-job.org, etc.), pass as query param: ?secret=YOUR_SECRET
# Note: If CRON_SECRET is not set, cron endpoints are publicly accessible (not recommended).
CRON_SECRET="your-cron-secret-change-in-production"

# ─── AI Analysis (Groq) ───────────────────────
# API key for Groq AI, used to generate monthly spending & savings analysis.
# Get your key at: https://console.groq.com/keys
# Note: This is optional. If not set, the monthly analysis cron job will report an error.
GROQ_API_KEY="gsk_your_groq_api_key_here"

# ─── Stock Price Updates ──────────────────────
# Yahoo Finance is used for stock prices and requires no API key.
# Rate limits are handled internally. If you encounter issues, reduce cron frequency.

# ─── Deployment (Optional) ────────────────────
# Your production domain — used for SEO (sitemap, robots.txt) and canonical URLs.
# Example: https://grandwealth.vercel.app
# If not set, defaults to http://localhost:3000
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
