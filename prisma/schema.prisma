generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String        @id @default(cuid())
  name          String?
  email         String        @unique
  emailVerified DateTime?
  image         String?
  password      String?
  budgetStartDay Int           @default(1)
  transactions         Transaction[]
  goldDeposits         GoldDeposit[]
  stocks               Stock[]
  categories           Category[]
  budgets              Budget[]
  recurringTransactions RecurringTransaction[]
  monthlyAnalyses       MonthlyAnalysis[]
  bankSavings           BankSaving[]
  accounts              Account[]
  sessions              Session[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

enum TransactionType {
  INCOME
  EXPENSE
}

model Transaction {
  id          String          @id @default(cuid())
  type        TransactionType
  category    String
  amount      Float
  description String
  date        DateTime        @default(now())
  userId      String
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
}

enum RuleType {
  NEED
  WANT
  SAVINGS
}

model Category {
  id        String    @id @default(cuid())
  name      String
  type      String    // INCOME or EXPENSE
  color     String    @default("#6366f1")
  ruleType  RuleType? // NEED, WANT, or SAVINGS for 50/30/20 budget rule
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@unique([name, userId])
}

model Budget {
  id              String   @id @default(cuid())
  categoryName    String
  amount          Float
  month           String   // format: "YYYY-MM"
  rolloverEnabled Boolean  @default(true)
  rolloverCap     Float?   // maximum rollover allowed, null means no cap
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([categoryName, month, userId])
}

enum GoldType {
  BUY
  SELL
}

model GoldDeposit {
  id           String   @id @default(cuid())
  type         GoldType
  weightGram   Float
  pricePerGram Float
  totalAmount  Float
  date         DateTime @default(now())
  notes        String?
  userId       String
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Stock {
  id               String    @id @default(cuid())
  symbol           String
  name             String
  quantity         Int
  buyPrice         Float
  currentPrice     Float?
  lastPriceUpdated DateTime?
  date             DateTime  @default(now())
  notes            String?
  userId           String
  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

enum RecurringFrequency {
  WEEKLY
  MONTHLY
  YEARLY
}

model RecurringTransaction {
  id          String              @id @default(cuid())
  type        TransactionType
  category    String
  amount      Float
  description String
  frequency   RecurringFrequency
  startDate   DateTime
  endDate     DateTime?
  nextDate    DateTime
  active      Boolean             @default(true)
  userId      String
  user        User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
}

enum SavingType {
  DEPOSIT
  WITHDRAWAL
}

model BankSaving {
  id          String     @id @default(cuid())
  type        SavingType
  accountName String
  amount      Float
  date        DateTime   @default(now())
  notes       String?
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model MonthlyAnalysis {
  id              String   @id @default(cuid())
  month           String   // format: "YYYY-MM"
  summary         String   // AI-generated analysis text (Markdown)
  totalIncome     Float
  totalExpenses   Float
  netSavings      Float
  savingsRate     Float    // percentage
  topCategory     String?  // top spending category
  topCategoryAmount Float?
  stockValue      Float?   // total stock portfolio value at month end
  goldValue       Float?   // total gold holdings value at month end
  budgetCount     Int      @default(0)  // number of budgets tracked
  overBudgetCount Int      @default(0)  // number of budgets exceeded
  transactionCount Int     @default(0)
  rawData         String   // JSON: snapshot of underlying data used
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([month, userId])
}
